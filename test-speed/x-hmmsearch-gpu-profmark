#! /usr/bin/env python3

import argparse
import pathlib
import subprocess
import re


def run(cmd, stderr_path=None, stdout_path=None):
    stdout = subprocess.DEVNULL if stdout_path is None else open(stdout_path, "w")
    stderr = subprocess.PIPE if stderr_path is None else open(stderr_path, "w")
    try:
        r = subprocess.run(cmd, stdout=stdout, stderr=stderr, text=True)
    finally:
        if stdout_path is not None:
            stdout.close()
        if stderr_path is not None:
            stderr.close()
    if r.returncode:
        detail = "" if stderr_path is not None else (r.stderr or "")
        raise SystemExit("FAILED: {}\n{}".format(" ".join(cmd), detail))


def timed(cmd, time_path):
    shell_cmd = ["/usr/bin/time", "-p"] + cmd
    run(shell_cmd, stderr_path=time_path)


def parse_real(path):
    for line in pathlib.Path(path).read_text().splitlines():
        fields = line.split()
        if len(fields) == 2 and fields[0] == "real":
            return float(fields[1])
    raise SystemExit("failed to parse real time from {}".format(path))


def parse_stat_from_lines(lines, label):
    for line in lines:
        if label in line:
            for field in line.split():
                try:
                    float(field)
                    return field
                except ValueError:
                    pass
    return "NA"


def parse_pass_count_from_lines(lines, label):
    for line in lines:
        if line.startswith(label):
            fields = line.split()
            if len(fields) >= 4:
                return fields[3]
    return "NA"


def names_for_query(tbl_path, query_name):
    result = set()
    for line in pathlib.Path(tbl_path).read_text().splitlines():
        if line.startswith("#") or not line.strip():
            continue
        fields = line.split()
        if len(fields) >= 3 and fields[2] == query_name:
            result.add(fields[0])
    return result


def split_gpu_output_by_query(gpu_out_path):
    """Split multi-query GPU output into per-query line blocks."""
    lines = pathlib.Path(gpu_out_path).read_text().splitlines()
    blocks = {}
    current_query = None
    current_lines = []
    for line in lines:
        m = re.match(r'^Query:\s+(\S+)', line)
        if m:
            if current_query is not None:
                blocks[current_query] = current_lines
            current_query = m.group(1)
            current_lines = [line]
        elif current_query is not None:
            current_lines.append(line)
    if current_query is not None:
        blocks[current_query] = current_lines
    return blocks


parser = argparse.ArgumentParser(description="Run CPU/GPU hmmsearch timing on local profmark data (multi-query)")
parser.add_argument("top_builddir")
parser.add_argument("profmark_workdir")
parser.add_argument("outdir")
parser.add_argument("queries", nargs="+")
parser.add_argument("--gpu-batch-seqs", default="32768")
parser.add_argument("--gpu-batch-res", default="8000000")
parser.add_argument("--gpu-load-seqs", default="32768")
parser.add_argument("--gpu-load-res", default="8000000")
parser.add_argument("--gpu-msv-slack", default="0")

parser.add_argument("--gpu-vit-compare", action="store_true")

parser.add_argument("--gpu-fwd-compare", action="store_true")

parser.add_argument("--gpu-fb-compare", action="store_true")
parser.add_argument("--gpu-previt-compare", action="store_true")
parser.add_argument("--gpu-vit-min-seqs", default="1")
parser.add_argument("--gpu-fwd-min-seqs", default="1")
parser.add_argument("--gpu-vit-min-res", default="0")
parser.add_argument("--gpu-fwd-min-res", default="0")
parser.add_argument("--gpu-vit-collect-seqs", default="0")
parser.add_argument("--gpu-fwd-collect-seqs", default="0")
parser.add_argument("--gpu-vit-collect-res", default="0")
parser.add_argument("--gpu-fwd-collect-res", default="0")
parser.add_argument("--gpu-vit-largem", action="store_true")
parser.add_argument("--gpu-fwd-largem", action="store_true")
parser.add_argument("--cpu-threads", default="0", help="Number of threads for CPU baseline (default: 0 = single-threaded)")
parser.add_argument("--tag", default="")
args = parser.parse_args()

top = pathlib.Path(args.top_builddir)
work = pathlib.Path(args.profmark_workdir)
out = pathlib.Path(args.outdir)
queries_dir = out / "queries"
logs = out / "logs"
queries_dir.mkdir(parents=True, exist_ok=True)
logs.mkdir(parents=True, exist_ok=True)

hmmbuild = top / "src" / "hmmbuild"
hmmpress = top / "src" / "hmmpress"
hmmseqdb = top / "src" / "hmmseqdb"
hmmsearch = top / "src" / "hmmsearch"
esl_afetch = top / "easel" / "miniapps" / "esl-afetch"
msafile = work / "pmark.train.msa"
targetdb = work / "pmark.test.fa"
gpu_targetdb = work / "pmark.test.gpudb"

if not (gpu_targetdb.with_suffix(gpu_targetdb.suffix + ".dsqi")).exists():
    run([str(hmmseqdb), str(targetdb), str(gpu_targetdb)], stdout_path=logs / "hmmseqdb.log")

# Build all HMMs
for q in args.queries:
    sto = queries_dir / (q + ".sto")
    hmm = queries_dir / (q + ".hmm")
    run([str(esl_afetch), "-o", str(sto), str(msafile), q])
    run([str(hmmbuild), str(hmm), str(sto)], stdout_path=logs / (q + ".hmmbuild.log"))

# Concatenate into single HMM file and press
all_hmm = queries_dir / "all.hmm"
with all_hmm.open("w") as fout:
    for q in args.queries:
        fout.write((queries_dir / (q + ".hmm")).read_text())
run([str(hmmpress), str(all_hmm)], stdout_path=logs / "hmmpress.log")

# Run CPU (single process, all queries)
cpu_tbl = logs / "all.cpu.tbl"
cpu_out = logs / "all.cpu.out"
cpu_time = logs / "all.cpu.time"
timed([str(hmmsearch), "--cpu", args.cpu_threads, "--noali",
       "-o", str(cpu_out), "--tblout", str(cpu_tbl),
       str(all_hmm), str(targetdb)], cpu_time)

# Run GPU (single process, all queries)
gpu_tbl = logs / "all.gpu.tbl"
gpu_out = logs / "all.gpu.out"
gpu_time = logs / "all.gpu.time"
gpu_cmd = [str(hmmsearch), "--gpu", "--cpu", "0",
           "--gpu-batch-seqs", args.gpu_batch_seqs,
           "--gpu-batch-res", args.gpu_batch_res,
           "--gpu-load-seqs", args.gpu_load_seqs,
           "--gpu-load-res", args.gpu_load_res,
           "--gpu-msv-slack", args.gpu_msv_slack,
           "--gpu-vit-min-seqs", args.gpu_vit_min_seqs,
           "--gpu-fwd-min-seqs", args.gpu_fwd_min_seqs,
           "--gpu-vit-min-res", args.gpu_vit_min_res,
           "--gpu-fwd-min-res", args.gpu_fwd_min_res,
           "--gpu-vit-collect-seqs", args.gpu_vit_collect_seqs,
           "--gpu-fwd-collect-seqs", args.gpu_fwd_collect_seqs,
           "--gpu-vit-collect-res", args.gpu_vit_collect_res,
           "--gpu-fwd-collect-res", args.gpu_fwd_collect_res]
if args.gpu_fwd_compare:
    gpu_cmd.append("--gpu-fwd-compare")
if args.gpu_fb_compare:
    gpu_cmd.append("--gpu-fb-compare")
if args.gpu_previt_compare:
    gpu_cmd.append("--gpu-previt-compare")
if args.gpu_vit_compare:
    gpu_cmd.append("--gpu-vit-compare")
if args.gpu_vit_largem:
    gpu_cmd.append("--gpu-vit-largem")
if args.gpu_fwd_largem:
    gpu_cmd.append("--gpu-fwd-largem")
gpu_cmd += ["--noali", "-o", str(gpu_out), "--tblout", str(gpu_tbl),
            str(all_hmm), str(gpu_targetdb)]
timed(gpu_cmd, gpu_time)

# Parse aggregate wall times
cpu_wall = parse_real(cpu_time)
gpu_wall = parse_real(gpu_time)

# Split GPU output by query
gpu_blocks = split_gpu_output_by_query(gpu_out)

# Write summary
summary = logs / "profmark-gpu-summary.tsv"
header_cols = [
    "query", "tag", "cpu_wall", "gpu_wall", "speedup", "cpu_only", "gpu_only",
    "past_msv", "past_bias", "past_vit", "past_fwd",
    "gpu_batches", "gpu_fwd_batches", "gpu_fwd_prefilter_batches",
    "gpu_fwd_parser_batches", "gpu_vit_batches", "gpu_bck_batches",
    "gpu_batch_seqs", "gpu_batch_res", "gpu_load_seqs", "gpu_load_res",
    "gpu_vit_min_seqs", "gpu_fwd_min_seqs", "gpu_vit_min_res", "gpu_fwd_min_res",
    "gpu_vit_collect_seqs", "gpu_fwd_collect_seqs", "gpu_vit_collect_res", "gpu_fwd_collect_res",
    "gpu_read", "gpu_meta", "gpu_survivor",
    "gpu_h2d", "gpu_kernel", "gpu_d2h",
    "gpu_dispatch_wait", "gpu_overlap_hidden_h2d", "gpu_overlap_hidden_d2h",
    "exact_gpu_submit_overhead", "exact_gpu_wait_barrier", "exact_gpu_event_overhead",
    "exact_cpu_survivor_total", "exact_cpu_postfwd", "exact_other_legacy", "exact_other",
    "gpu_null_h2d", "gpu_null_kernel", "gpu_null_d2h",
    "gpu_bias_h2d", "gpu_bias_kernel", "gpu_bias_d2h",
    "gpu_fwd_h2d", "gpu_fwd_kernel", "gpu_fwd_d2h", "gpu_fwd_sequences", "gpu_fwd_residues",
    "gpu_vit_h2d", "gpu_vit_kernel", "gpu_vit_d2h", "gpu_vit_sequences", "gpu_vit_residues",
    "gpu_bck_h2d", "gpu_bck_kernel", "gpu_bck_d2h", "gpu_bck_sequences", "gpu_bck_residues",
    "gpu_vit_candidates_total", "gpu_fwd_candidates_total",
    "gpu_vit_residues_total", "gpu_fwd_residues_total",
    "gpu_vit_launches", "gpu_fwd_launches",
    "gpu_vit_avg_cands_per_launch", "gpu_fwd_avg_cands_per_launch",
    "gpu_vit_avg_res_per_launch", "gpu_fwd_avg_res_per_launch",
    "stage_null", "stage_msv_host", "stage_bias", "stage_vit", "stage_fwd",
    "stage_bck", "stage_domain", "stage_null2_output",
]

total_cpu_only = 0
total_gpu_only = 0

with summary.open("w") as s:
    s.write("\t".join(header_cols) + "\n")
    for q in args.queries:
        cpu_names = names_for_query(cpu_tbl, q)
        gpu_names = names_for_query(gpu_tbl, q)
        q_cpu_only = len(cpu_names - gpu_names)
        q_gpu_only = len(gpu_names - cpu_names)
        total_cpu_only += q_cpu_only
        total_gpu_only += q_gpu_only

        lines = gpu_blocks.get(q, [])
        ps = lambda label: parse_stat_from_lines(lines, label)
        pc = lambda label: parse_pass_count_from_lines(lines, label)

        row = [
            q, args.tag, "{:.3f}".format(cpu_wall), "{:.3f}".format(gpu_wall),
            "{:.3f}".format(cpu_wall / gpu_wall if gpu_wall > 0 else 0.0),
            str(q_cpu_only), str(q_gpu_only),
            pc("Passed MSV filter:"), pc("Passed bias filter:"),
            pc("Passed Vit filter:"), pc("Passed Fwd filter:"),
            ps("CUDA MSV batches:"), ps("CUDA Forward batches:"),
            ps("CUDA Forward prefilter batches:"), ps("CUDA Forward parser batches:"),
            ps("CUDA Viterbi batches:"), ps("CUDA Backward batches:"),
            args.gpu_batch_seqs, args.gpu_batch_res, args.gpu_load_seqs, args.gpu_load_res,
            args.gpu_vit_min_seqs, args.gpu_fwd_min_seqs,
            args.gpu_vit_min_res, args.gpu_fwd_min_res,
            args.gpu_vit_collect_seqs, args.gpu_fwd_collect_seqs,
            args.gpu_vit_collect_res, args.gpu_fwd_collect_res,
            ps("GPU dsqdata read/unpack time:"), ps("GPU sequence metadata time:"),
            ps("GPU CPU survivor time:"),
            ps("CUDA MSV H2D time:"), ps("CUDA MSV kernel time:"), ps("CUDA MSV D2H time:"),
            ps("CUDA dispatch wait time:"), ps("CUDA overlap hidden H2D time:"), ps("CUDA overlap hidden D2H time:"),
            ps("Exact gpu_submit_overhead:"), ps("Exact gpu_wait_barrier:"), ps("Exact gpu_event_overhead:"),
            ps("Exact cpu_survivor_total:"), ps("Exact cpu_postfwd_domain_null2_output:"),
            ps("Exact other_legacy:"), ps("Exact other:"),
            ps("CUDA null H2D time:"), ps("CUDA null kernel time:"), ps("CUDA null D2H time:"),
            ps("CUDA bias H2D time:"), ps("CUDA bias kernel time:"), ps("CUDA bias D2H time:"),
            ps("CUDA Forward H2D time:"), ps("CUDA Forward kernel time:"), ps("CUDA Forward D2H time:"),
            ps("CUDA Forward sequences:"), ps("CUDA Forward residues:"),
            ps("CUDA Viterbi H2D time:"), ps("CUDA Viterbi kernel time:"), ps("CUDA Viterbi D2H time:"),
            ps("CUDA Viterbi sequences:"), ps("CUDA Viterbi residues:"),
            ps("CUDA Backward H2D time:"), ps("CUDA Backward kernel time:"), ps("CUDA Backward D2H time:"),
            ps("CUDA Backward sequences:"), ps("CUDA Backward residues:"),
            ps("CUDA Viterbi candidates total:"), ps("CUDA Forward candidates total:"),
            ps("CUDA Viterbi residues total:"), ps("CUDA Forward residues total:"),
            ps("CUDA Viterbi launches:"), ps("CUDA Forward launches:"),
            ps("CUDA Viterbi avg candidates/launch:"), ps("CUDA Forward avg candidates/launch:"),
            ps("CUDA Viterbi avg residues/launch:"), ps("CUDA Forward avg residues/launch:"),
            ps("Stage null time:"), ps("Stage MSV host time:"), ps("Stage bias time:"),
            ps("Stage Viterbi time:"), ps("Stage Forward time:"), ps("Stage Backward time:"),
            ps("Stage domain time:"), ps("Stage null2/output time:"),
        ]
        s.write("\t".join(row) + "\n")

    # TOTAL row
    total_row = [
        "TOTAL", args.tag, "{:.3f}".format(cpu_wall), "{:.3f}".format(gpu_wall),
        "{:.3f}".format(cpu_wall / gpu_wall if gpu_wall > 0 else 0.0),
        str(total_cpu_only), str(total_gpu_only),
    ] + [""] * (len(header_cols) - 7)
    s.write("\t".join(total_row) + "\n")

print("CPU wall: {:.2f}s  GPU wall: {:.2f}s  Speedup: {:.2f}x  cpu_only={} gpu_only={}".format(
    cpu_wall, gpu_wall, cpu_wall / gpu_wall if gpu_wall > 0 else 0.0,
    total_cpu_only, total_gpu_only))
