#!/bin/bash
# x-nhmmer-gpu-parity — Quick parity check: GPU hits must match CPU hits
#
# Usage:
#   test-speed/x-nhmmer-gpu-parity [builddir]
#
# Compares CPU nhmmer (on chr22.fa) to GPU nhmmer (on overlap .nucdb, the only
# supported --gpu target). Exits 0 if MADE1 parity holds.

set -euo pipefail

BUILDDIR="${1:-.}"
NHMMER="$BUILDDIR/src/nhmmer"
WORKDIR="$BUILDDIR/benchmark-data/nucleotide-bench/work"
CPU_TARGET="$WORKDIR/chr22.fa"
GPU_TARGET="$WORKDIR/chr22-overlap.nucdb.nucdb"
CPU_THREADS="${NHMMER_GPU_BENCH_CPU:-16}"

PASS=0
FAIL=0

check_parity() {
    local query="$1" label="$2" strict="$3"
    local hmm="$WORKDIR/$query.hmm"

    local cpu_hits gpu_hits
    cpu_hits=$("$NHMMER" --cpu "$CPU_THREADS" --noali "$hmm" "$CPU_TARGET" 2>/dev/null | grep -c "^  " || echo 0)
    gpu_hits=$("$NHMMER" --gpu --cpu "$CPU_THREADS" --noali "$hmm" "$GPU_TARGET" 2>/dev/null | grep -c "^  " || echo 0)

    if [ "$cpu_hits" -eq "$gpu_hits" ]; then
        printf "  PASS  %-15s %-18s %d = %d\n" "$query" "$label" "$cpu_hits" "$gpu_hits"
        PASS=$((PASS + 1))
    else
        local diff=$((cpu_hits - gpu_hits))
        if [ "$diff" -lt 0 ]; then diff=$((-diff)); fi
        local threshold=$((cpu_hits / 100 + 1))
        if [ "$strict" = "strict" ] && [ "$diff" -le "$threshold" ]; then
            printf "  PASS  %-15s %-18s CPU=%d GPU=%d (within 1%% tolerance)\n" "$query" "$label" "$cpu_hits" "$gpu_hits"
            PASS=$((PASS + 1))
        elif [ "$strict" = "strict" ]; then
            printf "  FAIL  %-15s %-18s CPU=%d GPU=%d\n" "$query" "$label" "$cpu_hits" "$gpu_hits"
            FAIL=$((FAIL + 1))
        else
            printf "  WARN  %-15s %-18s CPU=%d GPU=%d (known discrepancy)\n" "$query" "$label" "$cpu_hits" "$gpu_hits"
            PASS=$((PASS + 1))
        fi
    fi
}

echo "nhmmer GPU Parity Check"
echo "========================"
echo "CPU threads:  $CPU_THREADS"
echo "CPU target:   $CPU_TARGET"
echo "GPU target:   $GPU_TARGET"

check_parity "MADE1"        "CPU-fa vs GPU-nucdb" "strict"
check_parity "query_short"  "CPU-fa vs GPU-nucdb" "warn"
check_parity "query_medium" "CPU-fa vs GPU-nucdb" "warn"

echo "========================"
echo "Results: $PASS passed, $FAIL failed"

if [ "$FAIL" -gt 0 ]; then
    echo "PARITY FAILURE — investigate before merging"
    exit 1
fi
exit 0
