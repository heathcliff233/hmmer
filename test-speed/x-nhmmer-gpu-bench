#!/bin/bash
# x-nhmmer-gpu-bench — Quick benchmark: nhmmer GPU vs CPU on chr22
#
# Usage:
#   test-speed/x-nhmmer-gpu-bench [builddir]
#
# Runs MADE1, query_short, query_medium against chr22.fa and available nucdbs.
# By default it runs all query HMMs in one nhmmer process so startup, CUDA
# engine creation, and resident .nucdb upload are amortized across samples.
# Set NHMMER_GPU_BENCH_MODE=per-query for the old one-query-at-a-time view.
#
# Prerequisites:
#   - Build with --enable-cuda
#   - benchmark-data/nucleotide-bench/work/ must contain:
#     chr22.fa, MADE1.hmm, query_short.hmm, query_medium.hmm
#   - Optional: chr22.nucdb.nucdb (ordinary, built with: src/hmmnucdb --overlap 0 chr22.fa chr22.nucdb)
#   - Optional: chr22-overlap.nucdb.nucdb (default fast path, built with: src/hmmnucdb chr22.fa chr22-overlap.nucdb)

set -euo pipefail

BUILDDIR="${1:-.}"
NHMMER="$BUILDDIR/src/nhmmer"
HMMNUCDB="$BUILDDIR/src/hmmnucdb"
WORKDIR="$BUILDDIR/benchmark-data/nucleotide-bench/work"

if [ ! -x "$NHMMER" ]; then
    echo "ERROR: $NHMMER not found. Build first." >&2
    exit 1
fi

TARGET="$WORKDIR/chr22.fa"
NUCDB="$WORKDIR/chr22.nucdb.nucdb"
OVERLAP_NUCDB="$WORKDIR/chr22-overlap.nucdb.nucdb"
QUERIES=("MADE1" "query_short" "query_medium")
MODE="${NHMMER_GPU_BENCH_MODE:-all}"

if [ ! -f "$TARGET" ]; then
    echo "ERROR: $TARGET not found. See agents_docs/nucleotide-benchmark.md" >&2
    exit 1
fi

# Build ordinary nucdb (no overlap) if missing. This is a diagnostic baseline,
# not the fastest default construction.
if [ ! -f "$NUCDB" ] && [ -x "$HMMNUCDB" ]; then
    echo "Building ordinary nucdb (--overlap 0)..."
    "$HMMNUCDB" --overlap 0 "$TARGET" "$WORKDIR/chr22.nucdb" 2>/dev/null
fi

# Build overlap nucdb (default fast GPU-resident SSV path) if missing.
if [ ! -f "$OVERLAP_NUCDB" ] && [ -x "$HMMNUCDB" ]; then
    echo "Building overlap nucdb (default overlap)..."
    "$HMMNUCDB" "$TARGET" "$WORKDIR/chr22-overlap.nucdb" 2>/dev/null
fi

run_bench() {
    local label="$1"
    shift

    local start end elapsed hits
    start=$(date +%s%N)
    hits=$("$@" 2>/dev/null | grep -c "^  " || true)
    end=$(date +%s%N)
    elapsed=$(echo "scale=3; ($end - $start) / 1000000000" | bc)

    printf "  %-22s %6ss  %4d hits\n" "$label" "$elapsed" "$hits"
}

combined_hmm="$WORKDIR/nhmmer-gpu-all-samples.hmm"
: > "$combined_hmm"
for q in "${QUERIES[@]}"; do
    HMM="$WORKDIR/$q.hmm"
    if [ -f "$HMM" ]; then
        cat "$HMM" >> "$combined_hmm"
    fi
done

# Header
echo "================================================================"
echo "nhmmer GPU Benchmark — $(date '+%Y-%m-%d %H:%M')"
echo "Target: chr22.fa (50MB)"
echo "Mode: ${MODE}"
echo "GPU: $(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | head -1 || echo 'unknown')"
echo "================================================================"
echo

if [ "$MODE" = "all" ]; then
    if [ ! -s "$combined_hmm" ]; then
        echo "ERROR: no query HMMs found" >&2
        exit 1
    fi

    echo "--- all samples (${QUERIES[*]}) ---"
    run_bench "CPU-1" "$NHMMER" --cpu 1 --noali "$combined_hmm" "$TARGET"
    run_bench "CPU-4" "$NHMMER" --cpu 4 --noali "$combined_hmm" "$TARGET"

    if "$NHMMER" -h 2>&1 | grep -q "\-\-gpu"; then
        run_bench "GPU-4 (FASTA)" "$NHMMER" --gpu --cpu 4 --noali "$combined_hmm" "$TARGET"

        if [ -f "$NUCDB" ]; then
            run_bench "GPU-4 (nucdb-o0)" "$NHMMER" --gpu --cpu 4 --noali "$combined_hmm" "$NUCDB"
        fi

        if [ -f "$OVERLAP_NUCDB" ]; then
            run_bench "GPU-4 (nucdb-fast)" "$NHMMER" --gpu --cpu 4 --noali "$combined_hmm" "$OVERLAP_NUCDB"
        fi
    else
        echo "  (GPU not available — build with --enable-cuda)"
    fi
    echo
else
for q in "${QUERIES[@]}"; do
    HMM="$WORKDIR/$q.hmm"
    if [ ! -f "$HMM" ]; then
        echo "SKIP: $HMM not found"
        continue
    fi

    echo "--- $q ($(grep '^LENG' "$HMM" | awk '{print $2}') nodes) ---"

    run_bench "CPU-1" "$NHMMER" --cpu 1 --noali "$HMM" "$TARGET"
    run_bench "CPU-4" "$NHMMER" --cpu 4 --noali "$HMM" "$TARGET"

    # GPU requires --enable-cuda build
    if "$NHMMER" -h 2>&1 | grep -q "\-\-gpu"; then
        run_bench "GPU-4 (FASTA)" "$NHMMER" --gpu --cpu 4 --noali "$HMM" "$TARGET"

        if [ -f "$NUCDB" ]; then
            run_bench "GPU-4 (nucdb-o0)" "$NHMMER" --gpu --cpu 4 --noali "$HMM" "$NUCDB"
        fi

        if [ -f "$OVERLAP_NUCDB" ]; then
            run_bench "GPU-4 (nucdb-fast)" "$NHMMER" --gpu --cpu 4 --noali "$HMM" "$OVERLAP_NUCDB"
        fi
    else
        echo "  (GPU not available — build with --enable-cuda)"
    fi

    echo
done
fi

echo "================================================================"
echo "Parity check: CPU-4 hit count is reference. GPU hit counts should"
echo "match or stay within the documented smoke-test tolerance."
echo "================================================================"
